{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "digitprinters/dist",
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.digitprinters.site"
        }
      ],
      "destination": "https://digitprinters.site/:path*",
      "statusCode": 301
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
