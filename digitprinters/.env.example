# ========================================
# Deriv Configuration
# ========================================

# Deriv OAuth App ID (provided by Deriv)
# Used for OAuth flow initialization and websocket connection
VITE_DERIV_APP_ID=332LK4VWd9A4pEEfTMn53

# OAuth callback redirect URI
# Production: https://digitprinters.site/auth/callback
# Local: http://localhost:5173/auth/callback
VITE_DERIV_OAUTH_REDIRECT_URI=https://digitprinters.site/auth/callback

# ========================================
# Server-Side OAuth Configuration (Vercel)
# ========================================

# Deriv OAuth Client Secret (Backend only - never commit to repo)
# Set this in Vercel Environment Variables dashboard
# Used by /api/oauth-token endpoint to exchange code for access token
DERIV_OAUTH_CLIENT_SECRET=your_deriv_oauth_client_secret

# OAuth redirect URI for server-side token exchange
# If not set, defaults to https://digitprinters.site/auth/callback
DERIV_OAUTH_REDIRECT_URI=https://digitprinters.site/auth/callback

# ========================================
# Firebase Configuration
# ========================================

# Replace these with your actual Firebase project values
VITE_FIREBASE_API_KEY=YOUR_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID
VITE_FIREBASE_MEASUREMENT_ID=YOUR_MEASUREMENT_ID

# ========================================
# API Configuration
# ========================================

VITE_API_BASE_URL=https://api.digitprinters.local

# ========================================
# Environment Settings
# ========================================

VITE_ENV=development
